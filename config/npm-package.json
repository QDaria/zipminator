    "test": "node --test",
    "prepublishOnly": "npm run build-binaries"
  },
  "dependencies": {
    "@qdaria/zipminator-linux-x64": "1.0.0",
    "@qdaria/zipminator-linux-arm64": "1.0.0",
    "@qdaria/zipminator-darwin-x64": "1.0.0",
    "@qdaria/zipminator-darwin-arm64": "1.0.0",
    "@qdaria/zipminator-win32-x64": "1.0.0"
