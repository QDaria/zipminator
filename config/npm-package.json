{
  "name": "@qdaria/zipminator",
  "version": "1.0.0",
  "description": "Quantum-safe cryptography CLI with NIST Kyber768 and IBM QRNG (Rust binary wrapper)",
  "author": "QDaria <hello@qdaria.com>",
  "license": "MIT",
  "homepage": "https://qdaria.com/technology/products/zipminator",
  "repository": {
    "type": "git",
    "url": "https://github.com/qdaria/zipminator"
  },
  "bugs": {
    "url": "https://github.com/qdaria/zipminator/issues"
  },
  "keywords": [
    "quantum",
    "cryptography",
    "kyber768",
    "post-quantum",
    "qrng",
    "pqc",
    "nist"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "bin": {
