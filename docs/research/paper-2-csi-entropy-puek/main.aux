\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces PUEK enrollment and verification. (a)\nonbreakingspace At enrollment, $M$\nonbreakingspace CSI snapshots are decomposed via SVD; the top-$d$ right singular vectors form the location fingerprint. (b)\nonbreakingspace At verification, fresh snapshots yield $\mathbf  {V}_{\mathrm  {new}}$; subspace similarity $s$ is compared against threshold\nonbreakingspace $\tau $. On success, HKDF derives a location-locked key\nonbreakingspace $K$.}}{7}{figure.caption.21}\protected@file@percent }
\newlabel{fig:puek-protocol}{{4}{7}{PUEK enrollment and verification. (a)~At enrollment, $M$~CSI snapshots are decomposed via SVD; the top-$d$ right singular vectors form the location fingerprint. (b)~At verification, fresh snapshots yield $\mathbf {V}_{\mathrm {new}}$; subspace similarity $s$ is compared against threshold~$\tau $. On success, HKDF derives a location-locked key~$K$}{figure.caption.21}{}}
