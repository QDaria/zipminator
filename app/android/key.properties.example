# Android release signing configuration
# Copy this file to key.properties and fill in your values.
# NEVER commit key.properties to version control.
#
# Generate a keystore:
#   keytool -genkey -v -keystore ~/zipminator-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias zipminator-key
#
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=zipminator-key
storeFile=/path/to/zipminator-release.jks
