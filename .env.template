# Zipminator-PQC Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - only commit .env.template

# =============================================================================
# IBM Quantum Configuration
# =============================================================================
# Get your token from: https://quantum.ibm.com/
#
# IBM_QUANTUM_TOKEN is the current credential name.
# IBM_CLOUD_TOKEN is deprecated but still accepted by some older scripts.

IBM_QUANTUM_TOKEN="your_ibm_quantum_api_token_here"

# Backend selection (156-qubit Eagle r3 processors):
#   ibm_marrakesh  -- Primary (Marrakech, Morocco)
#   ibm_fez        -- Fallback (Fez, Morocco)
#   ibm_brisbane   -- 127-qubit alternative
# The QRNG harvester tries Marrakesh first, then falls back to Fez.
IBM_QUANTUM_BACKEND="ibm_marrakesh"

# Deprecated: use IBM_QUANTUM_TOKEN instead
# IBM_CLOUD_TOKEN="deprecated_use_IBM_QUANTUM_TOKEN"
# IBM_CLOUD_INSTANCE="open-instance"

# =============================================================================
# qBraid Configuration (OPTIONAL - Production Only)
# =============================================================================
# qBraid provides multi-provider quantum access with unified API
# Get your API key from: https://account.qbraid.com/
#
# Note: Zipminator handles all provider abstraction automatically.
# You don't need separate credentials for IonQ, AWS Braket, Rigetti, etc.

QBRAID_API_KEY=""

# =============================================================================
# Demo Application Configuration
# =============================================================================
FLASK_ENV="development"
FLASK_DEBUG="true"
DEMO_FRONTEND_PORT="3000"
DEMO_BACKEND_PORT="5000"

# =============================================================================
# Advanced Configuration (Optional - Production Only)
# =============================================================================
# These settings are handled automatically by Zipminator for demo usage

# Entropy pool directory
# ENTROPY_POOL_DIR="./production/entropy_pool"

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL="INFO"

# Use quantum simulator for testing (true = free, false = real hardware)
# USE_QUANTUM_SIMULATOR="true"

# =============================================================================
# OpenRouter Multi-Provider Paper Review
# =============================================================================
OPENROUTER_API_KEY=
OPENROUTER_MODEL_REVIEW=openai/gpt-5.4
OPENROUTER_MODEL_STRUCTURAL=google/gemini-3.1-pro-preview
OPENROUTER_MODEL_NOVELTY=xai/grok-4
OPENROUTER_MODEL_MATH=deepseek/deepseek-r1
OPENROUTER_MODEL_LIT=qwen/qwen-3.6
OPENROUTER_MODEL_LIT_ALT=zhipu/glm-5.1-mythos
