{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Zipminator",
  "version": "0.2.0",
  "identifier": "com.qdaria.zipminator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zipminator — Quantum-Secure Encryption",
        "width": 1280,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https: http://localhost:*; frame-src https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "signingIdentity": null
    },
    "category": "DeveloperTool",
    "shortDescription": "Quantum-secure encryption powered by real quantum hardware",
    "longDescription": "Zipminator-PQC: NIST FIPS 203 ML-KEM-768 encryption with real 156-qubit IBM quantum entropy. PQC browser, VPN, messenger, and email in one app."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
