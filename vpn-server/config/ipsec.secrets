# Zipminator Q-VPN Server — Secrets
#
# This file is overwritten at container startup by entrypoint.sh
# using the VPN_USERS environment variable. This placeholder exists
# only for reference.
#
# Format:
#   : RSA server-key.pem
#   username : EAP "password"

: RSA server-key.pem
zipminator : EAP "changeme-in-production"
