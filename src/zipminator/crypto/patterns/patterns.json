{
  "version": "1.0.0",
  "description": "Machine-readable PII patterns extracted from usa.py, uk.py, uae.py for cross-platform consumption",
  "patterns": [
    {
      "id": "us_ssn",
      "name": "US Social Security Number",
      "category": "national_id",
      "country_code": "us",
      "regex": "\\b\\d{3}[-\\s]?\\d{2}[-\\s]?\\d{4}\\b",
      "sensitivity": 5,
      "has_validator": true,
      "validator_type": "us_ssn"
    },
    {
      "id": "us_ein",
      "name": "US Employer Identification Number",
      "category": "tax_id",
      "country_code": "us",
      "regex": "\\b\\d{2}[-\\s]?\\d{7}\\b",
      "sensitivity": 4,
      "has_validator": true,
      "validator_type": "us_ein"
    },
    {
      "id": "us_drivers_license",
      "name": "US Driver's License",
      "category": "identity_document",
      "country_code": "us",
      "regex": "\\b[A-Z]{1,2}\\d{5,8}\\b",
      "sensitivity": 4,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_passport",
      "name": "US Passport Number",
      "category": "travel_document",
      "country_code": "us",
      "regex": "\\b[A-Z]{1,2}\\d{6,9}\\b",
      "sensitivity": 4,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_credit_card",
      "name": "Credit Card Number",
      "category": "financial",
      "country_code": "us",
      "regex": "\\b(?:\\d{4}[-\\s]?){3}\\d{4}\\b",
      "sensitivity": 5,
      "has_validator": true,
      "validator_type": "luhn"
    },
    {
      "id": "us_bank_account",
      "name": "US Bank Account Number",
      "category": "financial",
      "country_code": "us",
      "regex": "\\b\\d{8,17}\\b",
      "sensitivity": 5,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_routing_number",
      "name": "US Bank Routing Number",
      "category": "financial",
      "country_code": "us",
      "regex": "\\b\\d{9}\\b",
      "sensitivity": 4,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_email",
      "name": "Email Address",
      "category": "contact",
      "country_code": "us",
      "regex": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_phone",
      "name": "US Phone Number",
      "category": "contact",
      "country_code": "us",
      "regex": "\\b(?:\\+1\\s?)?(?:\\(\\d{3}\\)|\\d{3})[-\\s]?\\d{3}[-\\s]?\\d{4}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_zip_code",
      "name": "US ZIP Code",
      "category": "location",
      "country_code": "us",
      "regex": "\\b\\d{5}(?:-\\d{4})?\\b",
      "sensitivity": 2,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_vin",
      "name": "Vehicle Identification Number",
      "category": "vehicle",
      "country_code": "us",
      "regex": "\\b[A-HJ-NPR-Z0-9]{17}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_medicare_old",
      "name": "Medicare Number (Old Format)",
      "category": "health_id",
      "country_code": "us",
      "regex": "\\b\\d{3}[-\\s]?\\d{2}[-\\s]?\\d{4}[A-Z]\\b",
      "sensitivity": 5,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "us_medicare_new",
      "name": "Medicare Beneficiary Identifier",
      "category": "health_id",
      "country_code": "us",
      "regex": "\\b[1-9][A-C][A-HJ-NP-Z0-9]{2}[-\\s]?[A-HJ-NP-Z0-9]{2}[-\\s]?[A-HJ-NP-Z0-9]{4}\\b",
      "sensitivity": 5,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "uk_ni_number",
      "name": "UK National Insurance Number",
      "category": "national_id",
      "country_code": "uk",
      "regex": "\\b[A-CEGHJ-PR-TW-Z][A-CEGHJ-NPR-TW-Z]\\s?\\d{2}\\s?\\d{2}\\s?\\d{2}\\s?[A-D]\\b",
      "sensitivity": 5,
      "has_validator": true,
      "validator_type": "uk_ni"
    },
    {
      "id": "uk_nhs_number",
      "name": "UK NHS Number",
      "category": "health_id",
      "country_code": "uk",
      "regex": "\\b\\d{3}\\s?\\d{3}\\s?\\d{4}\\b",
      "sensitivity": 5,
      "has_validator": true,
      "validator_type": "nhs_mod11"
    },
    {
      "id": "uk_passport",
      "name": "UK Passport Number",
      "category": "travel_document",
      "country_code": "uk",
      "regex": "\\b\\d{9}\\b",
      "sensitivity": 4,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "uk_driving_license",
      "name": "UK Driving License",
      "category": "identity_document",
      "country_code": "uk",
      "regex": "\\b[A-Z]{5}\\d{6}[A-Z]{2}\\d[A-Z]{2}\\b",
      "sensitivity": 4,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "uk_bank_account",
      "name": "UK Bank Account",
      "category": "financial",
      "country_code": "uk",
      "regex": "\\b\\d{2}[-\\s]?\\d{2}[-\\s]?\\d{2}\\s+\\d{8}\\b",
      "sensitivity": 5,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "uk_credit_card",
      "name": "Credit Card Number",
      "category": "financial",
      "country_code": "uk",
      "regex": "\\b(?:\\d{4}[-\\s]?){3}\\d{4}\\b",
      "sensitivity": 5,
      "has_validator": true,
      "validator_type": "luhn"
    },
    {
      "id": "uk_email",
      "name": "Email Address",
      "category": "contact",
      "country_code": "uk",
      "regex": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "uk_phone",
      "name": "UK Phone Number",
      "category": "contact",
      "country_code": "uk",
      "regex": "\\b(?:\\+44\\s?|0)(?:\\d{2}\\s?\\d{4}\\s?\\d{4}|\\d{3}\\s?\\d{3}\\s?\\d{4})\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "uk_postcode",
      "name": "UK Postcode",
      "category": "location",
      "country_code": "uk",
      "regex": "\\b[A-Z]{1,2}\\d[A-Z\\d]?\\s?\\d[A-Z]{2}\\b",
      "sensitivity": 2,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "uk_vehicle_registration",
      "name": "UK Vehicle Registration",
      "category": "vehicle",
      "country_code": "uk",
      "regex": "\\b[A-Z]{2}\\d{2}\\s?[A-Z]{3}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "ae_emirates_id",
      "name": "UAE Emirates ID",
      "category": "national_id",
      "country_code": "ae",
      "regex": "\\b784[-\\s]?\\d{4}[-\\s]?\\d{7}[-\\s]?\\d\\b",
      "sensitivity": 5,
      "has_validator": true,
      "validator_type": "luhn"
    },
    {
      "id": "ae_tax_registration",
      "name": "UAE Tax Registration Number",
      "category": "tax_id",
      "country_code": "ae",
      "regex": "\\b\\d{15}\\b",
      "sensitivity": 4,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "ae_phone",
      "name": "UAE Phone Number",
      "category": "contact",
      "country_code": "ae",
      "regex": "\\b(?:\\+971|00971|971)?\\s?(?:50|52|54|55|56|58|2|3|4|6|7|9)\\s?\\d{3}\\s?\\d{4}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "ae_email",
      "name": "Email Address",
      "category": "contact",
      "country_code": "ae",
      "regex": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "ae_credit_card",
      "name": "Credit Card Number",
      "category": "financial",
      "country_code": "ae",
      "regex": "\\b(?:\\d{4}[-\\s]?){3}\\d{4}\\b",
      "sensitivity": 5,
      "has_validator": true,
      "validator_type": "luhn"
    },
    {
      "id": "ae_iban",
      "name": "UAE IBAN",
      "category": "financial",
      "country_code": "ae",
      "regex": "\\bAE\\d{21}\\b",
      "sensitivity": 5,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "ae_passport",
      "name": "UAE Passport Number",
      "category": "travel_document",
      "country_code": "ae",
      "regex": "\\b[A-Z]\\d{7}\\b",
      "sensitivity": 4,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "ae_trade_license",
      "name": "UAE Trade License",
      "category": "business_id",
      "country_code": "ae",
      "regex": "\\b\\d{6,10}\\b",
      "sensitivity": 3,
      "has_validator": false,
      "validator_type": null
    },
    {
      "id": "ae_po_box",
      "name": "UAE P.O. Box",
      "category": "location",
      "country_code": "ae",
      "regex": "\\b(?:P\\.?\\s?O\\.?\\s?Box|PO Box)\\s?\\d+\\b",
      "sensitivity": 2,
      "has_validator": false,
      "validator_type": null
    }
  ]
}
